{
  "name": "@shelby-protocol/solana-kit",
  "version": "0.2.7",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./node": {
      "types": "./dist/node/index.d.ts",
      "require": "./dist/node/index.cjs",
      "import": "./dist/node/index.mjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs"
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "19.2.1",
    "@types/react-dom": "19.2.1",
    "happy-dom": "^20.0.10",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@aptos-labs/derived-wallet-solana": "^0.12.0",
    "@aptos-labs/gas-station-client": "^2.0.3",
    "@aptos-labs/ts-sdk": "5.2.1",
    "@aptos-labs/wallet-standard": "^0.5.2",
    "@solana/wallet-standard-features": "^1.3.0",
    "@solana/web3.js": "^1.95.8",
    "@shelby-protocol/sdk": "0.3.0"
  },
  "scripts": {
    "lint": "biome check .",
    "fmt": "biome check . --write",
    "build": "tsc --noEmit && (rimraf dist; tsup)",
    "test": "vitest dev",
    "test:once": "vitest run"
  }
}